<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="774"
        Width="1044"
        Loaded="Window_Loaded"
        Background="#0F1923"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="SidePanelButton" TargetType="Button">
            <Setter Property="Background" Value="#1C2E4A"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A4A7F"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A4A7F"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- TOP BUTTONS -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,10"
                    Grid.Row="0">

            <Button Content="📜  Chat History"
                    Style="{StaticResource TopButton}"
                    Background="#1E3A5F"
                    Foreground="#A0BFE0"
                    Click="BtnChatbot_Click"/>

            <Button x:Name="BtnHelp"
                    Content="❓  Help"
                    Style="{StaticResource TopButton}"
                    Background="#1C2E4A"
                    Foreground="#A0BFE0"
                    Click="BtnHelp_Click"/>

            <Button Content="🗑  Clear Chat"
                    Style="{StaticResource TopButton}"
                    Background="#2C1A1A"
                    Foreground="#E57373"
                    Click="BtnClear_Click"/>

        </StackPanel>

        <!-- HEADER -->
        <Border Grid.Row="1"
                CornerRadius="8"
                Margin="0,0,0,10"
                BorderThickness="1"
                BorderBrush="#1E3A5F">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0F1923" Offset="0"/>
                    <GradientStop Color="#1E3A5F" Offset="0.5"/>
                    <GradientStop Color="#0F1923" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🛡   CYBERSECURITY AWARENESS BOT   🛡"
                           FontFamily="Segoe UI"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#7EB8F7"
                           TextAlignment="Center"/>
                <TextBlock Text="Stay safe. Stay smart. Stay secure."
                           FontFamily="Segoe UI"
                           FontSize="12"
                           Foreground="#4A7FAF"
                           TextAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- MAIN CHAT AREA -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="265"/>
            </Grid.ColumnDefinitions>

            <!-- CHAT WINDOW -->
            <Border Grid.Column="0"
                    CornerRadius="8"
                    Margin="0,0,10,0"
                    BorderBrush="#1E3A5F"
                    BorderThickness="1"
                    Background="#111D2B">
                <ListBox x:Name="ChatHistory"
                         Background="Transparent"
                         Foreground="#CBD5E1"
                         FontSize="14"
                         FontFamily="Segoe UI"
                         BorderThickness="0"
                         Padding="10"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="True">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,5"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#CBD5E1"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#162032"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>

            <!-- SIDE PANEL -->
            <Border Grid.Column="1"
                    CornerRadius="8"
                    BorderBrush="#1E3A5F"
                    BorderThickness="1"
                    Background="#111D2B">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>

                        <TextBlock Text="QUICK TOPICS"
                                   Foreground="#4A7FAF"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   Margin="0,0,0,8"/>

                        <Button Content="🎣   Phishing"
                                Style="{StaticResource SidePanelButton}"
                                Click="QuickTopic_Click"
                                Tag="phishing"/>
                        <Button Content="🔑   Passwords"
                                Style="{StaticResource SidePanelButton}"
                                Click="QuickTopic_Click"
                                Tag="password"/>
                        <Button Content="🕵   Online Scams"
                                Style="{StaticResource SidePanelButton}"
                                Click="QuickTopic_Click"
                                Tag="scam"/>
                        <Button Content="🔒   Privacy"
                                Style="{StaticResource SidePanelButton}"
                                Click="QuickTopic_Click"
                                Tag="privacy"/>
                        <Button Content="🌐   Cybersecurity"
                                Style="{StaticResource SidePanelButton}"
                                Click="QuickTopic_Click"
                                Tag="cybersecurity"/>

                        <Rectangle Height="1" Fill="#1E3A5F" Margin="0,12"/>

                        <!-- FAVORITE TOPICS SECTION ADDED -->
                        <TextBlock Text="⭐  MY FAVORITE TOPICS"
                                   Foreground="#FFD700"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   Margin="0,0,0,8"/>

                        <Border Background="#0F1923"
                                CornerRadius="6"
                                BorderBrush="#1E3A5F"
                                BorderThickness="1"
                                Padding="8"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel x:Name="FavoriteTopicsPanel">
                                    <TextBlock Text="No saved favorites yet.&#10;Say 'I'm interested in [topic]' to save!"
                                               Foreground="#4A7FAF"
                                               FontSize="10"
                                               TextAlignment="Center"
                                               FontFamily="Segoe UI"
                                               Margin="0,5"/>
                                </StackPanel>
                                <Button Content="📌  Save Current Interest"
                                        Background="#1E3A5F"
                                        Foreground="#FFD700"
                                        FontSize="11"
                                        Height="28"
                                        Margin="0,8,0,0"
                                        Cursor="Hand"
                                        BorderThickness="0"
                                        Click="SaveCurrentInterest_Click"/>
                                <Button Content="🗑  Clear Favorites"
                                        Background="#2C1A1A"
                                        Foreground="#E57373"
                                        FontSize="11"
                                        Height="28"
                                        Margin="0,4,0,0"
                                        Cursor="Hand"
                                        BorderThickness="0"
                                        Click="ClearFavorites_Click"/>
                            </StackPanel>
                        </Border>

                        <Rectangle Height="1" Fill="#1E3A5F" Margin="0,12"/>

                        <TextBlock Text="FOLLOW-UPS"
                                   Foreground="#4A7FAF"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   Margin="0,0,0,8"/>

                        <Button Content="💡   Another Tip"
                                Style="{StaticResource SidePanelButton}"
                                Click="QuickTopic_Click"
                                Tag="another tip"/>
                        <Button Content="📖   Tell Me More"
                                Style="{StaticResource SidePanelButton}"
                                Click="QuickTopic_Click"
                                Tag="tell me more"/>
                        <Button Content="🔁   Remind Me"
                                Style="{StaticResource SidePanelButton}"
                                Click="QuickTopic_Click"
                                Tag="remind me"/>

                        <Rectangle Height="1" Fill="#1E3A5F" Margin="0,12"/>

                        <TextBlock Text="FEATURES"
                                   Foreground="#4A7FAF"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="✔  Keyword Recognition" Foreground="#4A7FAF" FontSize="12" FontFamily="Segoe UI" Margin="0,3"/>
                        <TextBlock Text="✔  Sentiment Detection"  Foreground="#4A7FAF" FontSize="12" FontFamily="Segoe UI" Margin="0,3"/>
                        <TextBlock Text="✔  Memory &amp; Recall"  Foreground="#4A7FAF" FontSize="12" FontFamily="Segoe UI" Margin="0,3"/>
                        <TextBlock Text="✔  Conversation Flow"    Foreground="#4A7FAF" FontSize="12" FontFamily="Segoe UI" Margin="0,3"/>
                        <TextBlock Text="✔  Follow-up Questions"  Foreground="#4A7FAF" FontSize="12" FontFamily="Segoe UI" Margin="0,3"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>

        <!-- INPUT AREA -->
        <Border Grid.Row="3"
                CornerRadius="8"
                Margin="0,10,0,0"
                BorderBrush="#1E3A5F"
                BorderThickness="1"
                Background="#111D2B"
                Padding="10,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBox x:Name="UserInput"
                         Width="670"
                         Height="44"
                         FontSize="15"
                         FontFamily="Segoe UI"
                         Margin="0,0,10,0"
                         Background="#0F1923"
                         Foreground="#CBD5E1"
                         CaretBrush="#7EB8F7"
                         BorderBrush="#1E3A5F"
                         BorderThickness="1"
                         Padding="12,8"
                         VerticalContentAlignment="Center"/>

                <Button Content="➤  SEND"
                        Width="115"
                        Height="44"
                        FontWeight="Bold"
                        FontSize="14"
                        Margin="0,0,8,0"
                        Cursor="Hand"
                        Click="SendButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1E3A5F"/>
                            <Setter Property="Foreground" Value="#7EB8F7"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2A4A7F"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="✖  EXIT"
                        Width="115"
                        Height="44"
                        Cursor="Hand"
                        Click="ExitButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2C1A1A"/>
                            <Setter Property="Foreground" Value="#E57373"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4A1A1A"/>
                                    <Setter Property="Foreground" Value="#EF9A9A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>

    </Grid>
</Window>